datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  email                     String?         @unique
  username                  String?         @unique
  isAdmin                   Boolean         @default(false)

  paymentProcessorUserId    String?         @unique
  lemonSqueezyCustomerPortalUrl String?     // You can delete this if you're not using Lemon Squeezy as your payments processor.
  subscriptionStatus        String?         // 'active', 'cancel_at_period_end', 'past_due', 'deleted'
  subscriptionPlan          String?         // 'hobby', 'pro'
  datePaid                  DateTime?
  credits                   Int             @default(3)
  contactFormMessages       ContactFormMessage[]
  submissions               Submission[]
  projects                  Project[]
  files                     File[]
  aspectRatios              AspectRatio[]
  appPermissions            UserAppPermission[]
}

model UserAppPermission {
  id        String   @id @default(uuid())
  userId    String
  appKey    String   // e.g. 'sokafilm', 'online-judge'
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, appKey])
}



model DailyStats {
  id                               Int             @id @default(autoincrement())
  date                             DateTime        @default(now()) @unique

  totalViews                       Int             @default(0)
  prevDayViewsChangePercent        String          @default("0")
  userCount                        Int             @default(0)
  paidUserCount                    Int             @default(0)
  userDelta                        Int             @default(0)
  paidUserDelta                    Int             @default(0)
  totalRevenue                     Float           @default(0)
  totalProfit                      Float           @default(0)

  sources                          PageViewSource[]
}

model PageViewSource {
  @@id([date, name])
  name                     String
  date                     DateTime        @default(now())

  dailyStats               DailyStats?     @relation(fields: [dailyStatsId], references: [id])
  dailyStatsId             Int?

  visitors                 Int
}

model Logs {
  id                       Int             @id @default(autoincrement())
  createdAt                DateTime        @default(now())

  message                  String
  level                    String
}

model ContactFormMessage {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
  isRead                    Boolean         @default(false)
  repliedAt                 DateTime?
}

model Problem {
  id                        String          @id @default(uuid())
  title                     String
  slug                      String          @unique
  description               String
  difficulty                String          @default("Easy") // Easy, Medium, Hard
  timeLimit                 Int             @default(1) // Seconds
  memoryLimit               Int             @default(128) // MB
  starterCode               String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  testCases                 TestCase[]
  submissions               Submission[]
}

model TestCase {
  id                        String          @id @default(uuid())
  problem                   Problem         @relation(fields: [problemId], references: [id])
  problemId                 String

  input                     String
  expectedOutput            String
  isSample                  Boolean         @default(false)
  createdAt                 DateTime        @default(now())
  
  submissionResults         SubmissionTestCaseResult[]
}

model Submission {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  problem                   Problem         @relation(fields: [problemId], references: [id])
  problemId                 String

  code                      String
  language                  String
  status                    SubmissionStatus @default(PENDING)
  executionTime             Int?            // Total time in ms

  runtime                   Runtime?        @relation(fields: [runtimeId], references: [id])
  runtimeId                 String?

  testCaseResults           SubmissionTestCaseResult[]
}

model SubmissionTestCaseResult {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  submission                Submission      @relation(fields: [submissionId], references: [id])
  submissionId              String

  testCase                  TestCase?       @relation(fields: [testCaseId], references: [id], onDelete: SetNull)
  testCaseId                String?

  status                    SubmissionStatus
  stdout                    String?
  executionTime             Int? // ms
  memoryUsage               Int? // MB
  
  // Snapshot of the test case at the time of submission
  input                     String          @default("")
  expectedOutput            String          @default("")
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  COMPILATION_ERROR
  RUNTIME_ERROR
  SYSTEM_ERROR
}

model Runtime {
  id                        String          @id @default(uuid())
  language                  String          @unique // e.g., "javascript", "python"
  defaultCode               String          @default("")
  
  // Execution Configuration
  dockerImage               String          @default("node:18-alpine")
  runCommand                String          @default("node solution.js")
  fileName                  String          @default("solution.js")
  memoryLimit               Int             @default(128) // MB
  cpuLimit                  Float           @default(0.5) // CPUs

  submissions               Submission[]
}

// === SokaFilm module ===

model File {
  uuid                      String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  fileName                  String
  fileType                  String
  fileUrl                   String?

  taskType                  String?
  pgBossJobId               String?

  taskInput                 Json?
  modelConfig               Json?

  status                    String?
  progress                  Float?
  startedAt                 DateTime?
  completedAt               DateTime?
  errorMessage              String?
}

model Project {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  description               String?
  thumbnailUuid             String?

  isArchived                Boolean         @default(false)
  aiSettings                Json?

  characters                Character[]
  stories                   Story[]
}

model Character {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  project                   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId                 String

  serial                    Int
  name                      String
  description               String?
  refImageUuid              String?
  refVoiceUuid              String?
  finalImageUuid             String?

  dialogs                   Dialog[]
  sceneCharacters           SceneCharacter[]
  storyCharacters           StoryCharacter[]
  shotCharacters            ShotCharacter[]
}

model Story {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  project                   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId                 String

  serial                    Int
  title                     String
  description               String?
  script                    String?

  aspectRatio               AspectRatio?    @relation(fields: [aspectRatioId], references: [id])
  aspectRatioId             String?

  scenes                    Scene[]
  storyCharacters           StoryCharacter[]
}

model StoryCharacter {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  story                     Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId                   String

  character                 Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId               String

  customDescription         String?
  customImageUuid           String?

  @@unique([storyId, characterId])
}

model Scene {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  story                     Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId                   String

  serial                    Int
  title                     String
  description               String?
  summary                   String?
  overviewImageUuid         String?

  shots                     Shot[]
  sceneCharacters           SceneCharacter[]
  dialogs                   Dialog[]
}

model Shot {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  scene                     Scene           @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId                   String

  revision                  Int             @default(1)
  sequence                  Int
  title                     String
  description               String?
  motionDescription         String?
  thumbnailUuid             String?

  shotImages                ShotImage[]
  shotCharacters            ShotCharacter[]
}

model ShotCharacter {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  shot                      Shot            @relation(fields: [shotId], references: [id], onDelete: Cascade)
  shotId                    String

  character                 Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId               String

  @@unique([shotId, characterId])
}

model Dialog {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  character                 Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId               String

  scene                     Scene?          @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId                   String?

  text                      String
  startEpochMilliseconds    BigInt
  soundUuid                 String?
}

model SceneCharacter {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  scene                     Scene           @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId                   String

  character                 Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId               String

  @@unique([sceneId, characterId])
}

model AspectRatio {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  name                      String
  width                     Int
  height                    Int
  isDefault                 Boolean         @default(false)

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  stories                   Story[]
  shotImages                ShotImage[]

  @@unique([userId, width, height])
}

model ShotImage {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  shot                      Shot            @relation(fields: [shotId], references: [id], onDelete: Cascade)
  shotId                    String

  aspectRatio               AspectRatio     @relation(fields: [aspectRatioId], references: [id])
  aspectRatioId             String

  imageUuid                 String

  @@unique([shotId, aspectRatioId])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
