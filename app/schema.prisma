datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  email                     String?         @unique
  username                  String?         @unique
  isAdmin                   Boolean         @default(false)

  paymentProcessorUserId    String?         @unique
  lemonSqueezyCustomerPortalUrl String?     // You can delete this if you're not using Lemon Squeezy as your payments processor.
  subscriptionStatus        String?         // 'active', 'cancel_at_period_end', 'past_due', 'deleted'
  subscriptionPlan          String?         // 'hobby', 'pro'
  datePaid                  DateTime?
  credits                   Int             @default(3)
  contactFormMessages       ContactFormMessage[]
  submissions               Submission[]
  projects                  Project[]
  files                     File[]
  aspectRatios              AspectRatio[]
  appPermissions            UserAppPermission[]
  redditBotProjects         RedditBotProject[]
  redditCreditAccount       RedditCreditAccount?
  redditCreditTransactions  RedditCreditTransaction[]
  careParentsCreated        CarelyParent[] @relation("CareParentsCreated")
  carelyCollaborators       CarelyCollaborator[] @relation("CarelyCollaborators")
  careVitalLogs             CarelyVitalLog[] @relation("CareVitalLogs")
  carePrescriptions         CarelyPrescription[] @relation("CarePrescriptions")
  careMedicineIntakeLogs    CarelyMedicineIntakeLog[] @relation("CareMedicineIntakeLogs")
}

model UserAppPermission {
  id        String   @id @default(uuid())
  userId    String
  appKey    String   // e.g. 'sokafilm', 'online-judge'
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, appKey])
}



model DailyStats {
  id                               Int             @id @default(autoincrement())
  date                             DateTime        @default(now()) @unique

  totalViews                       Int             @default(0)
  prevDayViewsChangePercent        String          @default("0")
  userCount                        Int             @default(0)
  paidUserCount                    Int             @default(0)
  userDelta                        Int             @default(0)
  paidUserDelta                    Int             @default(0)
  totalRevenue                     Float           @default(0)
  totalProfit                      Float           @default(0)

  sources                          PageViewSource[]
}

model PageViewSource {
  @@id([date, name])
  name                     String
  date                     DateTime        @default(now())

  dailyStats               DailyStats?     @relation(fields: [dailyStatsId], references: [id])
  dailyStatsId             Int?

  visitors                 Int
}

model Logs {
  id                       Int             @id @default(autoincrement())
  createdAt                DateTime        @default(now())

  message                  String
  level                    String
}

model ContactFormMessage {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
  isRead                    Boolean         @default(false)
  repliedAt                 DateTime?
}

model Problem {
  id                        String          @id @default(uuid())
  title                     String
  slug                      String          @unique
  description               String
  difficulty                String          @default("Easy") // Easy, Medium, Hard
  timeLimit                 Int             @default(1) // Seconds
  memoryLimit               Int             @default(128) // MB
  starterCode               String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  testCases                 TestCase[]
  submissions               Submission[]
}

model TestCase {
  id                        String          @id @default(uuid())
  problem                   Problem         @relation(fields: [problemId], references: [id])
  problemId                 String

  input                     String
  expectedOutput            String
  isSample                  Boolean         @default(false)
  createdAt                 DateTime        @default(now())
  
  submissionResults         SubmissionTestCaseResult[]
}

model Submission {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  problem                   Problem         @relation(fields: [problemId], references: [id])
  problemId                 String

  code                      String
  language                  String
  status                    SubmissionStatus @default(PENDING)
  executionTime             Int?            // Total time in ms

  runtime                   Runtime?        @relation(fields: [runtimeId], references: [id])
  runtimeId                 String?

  testCaseResults           SubmissionTestCaseResult[]
}

model SubmissionTestCaseResult {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  submission                Submission      @relation(fields: [submissionId], references: [id])
  submissionId              String

  testCase                  TestCase?       @relation(fields: [testCaseId], references: [id], onDelete: SetNull)
  testCaseId                String?

  status                    SubmissionStatus
  stdout                    String?
  executionTime             Int? // ms
  memoryUsage               Int? // MB
  
  // Snapshot of the test case at the time of submission
  input                     String          @default("")
  expectedOutput            String          @default("")
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  COMPILATION_ERROR
  RUNTIME_ERROR
  SYSTEM_ERROR
}

model Runtime {
  id                        String          @id @default(uuid())
  language                  String          @unique // e.g., "javascript", "python"
  defaultCode               String          @default("")
  
  // Execution Configuration
  dockerImage               String          @default("node:18-alpine")
  runCommand                String          @default("node solution.js")
  fileName                  String          @default("solution.js")
  memoryLimit               Int             @default(128) // MB
  cpuLimit                  Float           @default(0.5) // CPUs

  submissions               Submission[]
}

// === SokaFilm module ===

model File {
  uuid                      String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  fileName                  String
  fileType                  String
  fileUrl                   String?

  taskType                  String?
  pgBossJobId               String?

  taskInput                 Json?
  modelConfig               Json?

  status                    String?
  progress                  Float?
  startedAt                 DateTime?
  completedAt               DateTime?
  errorMessage              String?
}

model Project {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  description               String?
  thumbnailUuid             String?

  isArchived                Boolean         @default(false)
  aiSettings                Json?

  characters                Character[]
  stories                   Story[]
}

model Character {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  project                   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId                 String

  serial                    Int
  name                      String
  description               String?
  refImageUuid              String?
  refVoiceUuid              String?
  finalImageUuid             String?

  dialogs                   Dialog[]
  sceneCharacters           SceneCharacter[]
  storyCharacters           StoryCharacter[]
  shotCharacters            ShotCharacter[]
}

model Story {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  project                   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId                 String

  serial                    Int
  title                     String
  description               String?
  script                    String?

  aspectRatio               AspectRatio?    @relation(fields: [aspectRatioId], references: [id])
  aspectRatioId             String?

  scenes                    Scene[]
  storyCharacters           StoryCharacter[]
}

model StoryCharacter {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  story                     Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId                   String

  character                 Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId               String

  customDescription         String?
  customImageUuid           String?

  @@unique([storyId, characterId])
}

model Scene {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  story                     Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId                   String

  serial                    Int
  title                     String
  description               String?
  summary                   String?
  overviewImageUuid         String?

  shots                     Shot[]
  sceneCharacters           SceneCharacter[]
  dialogs                   Dialog[]
}

model Shot {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  scene                     Scene           @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId                   String

  revision                  Int             @default(1)
  sequence                  Int
  title                     String
  description               String?
  motionDescription         String?
  thumbnailUuid             String?

  shotImages                ShotImage[]
  shotCharacters            ShotCharacter[]
}

model ShotCharacter {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  shot                      Shot            @relation(fields: [shotId], references: [id], onDelete: Cascade)
  shotId                    String

  character                 Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId               String

  @@unique([shotId, characterId])
}

model Dialog {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  character                 Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId               String

  scene                     Scene?          @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId                   String?

  text                      String
  startEpochMilliseconds    BigInt
  soundUuid                 String?
}

model SceneCharacter {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  scene                     Scene           @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId                   String

  character                 Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId               String

  @@unique([sceneId, characterId])
}

model AspectRatio {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  name                      String
  width                     Int
  height                    Int
  isDefault                 Boolean         @default(false)

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  stories                   Story[]
  shotImages                ShotImage[]

  @@unique([userId, width, height])
}

model ShotImage {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  shot                      Shot            @relation(fields: [shotId], references: [id], onDelete: Cascade)
  shotId                    String

  aspectRatio               AspectRatio     @relation(fields: [aspectRatioId], references: [id])
  aspectRatioId             String

  imageUuid                 String

  @@unique([shotId, aspectRatioId])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// === Reddit Bot (lead generation) ===

enum RedditBotProjectPostStatus {
  DOWNLOADED // downloaded from Reddit, no keyword match
  MATCH      // keyword matched during exploration
  RELEVANT   // AI analysis said relevant (pain point found)
  DISCARDED  // AI said not relevant, or user discarded
}

enum RedditBotJobStatus {
  RUNNING
  COMPLETED
  FAILED
  KILLED
}

enum RedditBotAiAnalysisRunStatus {
  RUNNING
  COMPLETED
  FAILED
  KILLED
}

enum RedditBotAiAnalysisStatus {
  NOT_REQUESTED
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model RedditBotProject {
  id                 String    @id @default(uuid())
  createdAt          DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  productDescription String    @default("")
  subreddits         Json      // e.g. ["webdev", "startups"]
  keywords           Json      // e.g. ["saas", "pricing"]

  projectPosts       RedditBotProjectPost[]
  schedules          RedditBotSchedule[]
  jobs               RedditBotJob[]
  aiAnalysisRuns     RedditBotAiAnalysisRun[]
}

model RedditBotAuthor {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  redditUsername String   @unique
  profileUrl     String

  posts          RedditBotPost[]
}

model RedditBotPost {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  redditId  String   @unique
  title     String
  content   String   @default("")
  postLink  String
  authorId  String
  author    RedditBotAuthor @relation(fields: [authorId], references: [id], onDelete: Cascade)
  subreddit String
  postedAt  DateTime?

  projectPosts RedditBotProjectPost[]
}

model RedditBotProjectPost {
  id               String                   @id @default(uuid())
  createdAt        DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  projectId       String
  project         RedditBotProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  postId          String
  post            RedditBotPost             @relation(fields: [postId], references: [id], onDelete: Cascade)
  status          RedditBotProjectPostStatus @default(DOWNLOADED)
  painPointSummary String?
  aiReasoning      String?
  matchedKeywords Json?
  aiAnalysisStatus     RedditBotAiAnalysisStatus @default(NOT_REQUESTED)
  aiAnalysisErrorMessage String?
  jobId               String?
  job                 RedditBotJob?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  lastExportedAt      DateTime?

  @@unique([projectId, postId])
}

model RedditBotSchedule {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projectId     String
  project       RedditBotProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String
  enabled       Boolean   @default(true)
  cronExpression String?
  runAtTime     String?
  config        Json?     // { subreddits?, keywords?, relativeDateRange?, maxPostsToExplore?, maxLeadsToFind? }
  nextRunAt     DateTime?
  lastRunAt     DateTime?

  jobs          RedditBotJob[]
}

model RedditBotJob {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())
  projectId       String
  project         RedditBotProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scheduleId      String?
  schedule        RedditBotSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  status          RedditBotJobStatus @default(RUNNING)
  uniqueCount         Int              @default(0)  // unique posts added this run
  keywordMatchCount   Int              @default(0)  // of those, keyword-matched
  totalProcessed  Int              @default(0)  // total post processings (incl. duplicates seen)
  aiAnalysisSkippedCount Int        @default(0)  // posts skipped for auto AI (already analysed)
  completedAt     DateTime?
  errorMessage    String?
  stopRequestedAt DateTime?
  config          Json?            // subreddits, keywords, relativeDateRange, maxPostsToExplore, maxLeadsToFind
  redditApiCalls   Int              @default(0)
  redditCreditsUsed Decimal         @default(0) @db.Decimal(12, 4)
  creditTransactions RedditCreditTransaction[]
  projectPostsFromJob RedditBotProjectPost[]
}

model RedditBotAiAnalysisRun {
  id                    String                      @id @default(uuid())
  createdAt             DateTime                    @default(now())
  projectId             String
  project               RedditBotProject             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggerSource         String                      // "manual" | "exploration"
  explorationJobId      String?
  filterSnapshot        Json?                       // optional filter snapshot
  status                RedditBotAiAnalysisRunStatus @default(RUNNING)
  totalToProcess        Int                         @default(0)
  processedCount        Int                         @default(0)
  errorMessage          String?
  stopRequestedAt      DateTime?
}

model RedditSettings {
  id    String @id @default(cuid())
  key   String @unique // e.g. "credits.defaultForNewUser", "bottleneck.redis.host"
  value Json   // string | number | boolean; store in JSON
}

model RedditCreditAccount {
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal  @default(0) @db.Decimal(12, 4)
  totalUsed Decimal  @default(0) @db.Decimal(12, 4)
}

model RedditCreditTransaction {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal       @db.Decimal(12, 4) // positive = top-up, negative = deduction
  reason    String        // "topup", "reddit_api_call"
  jobId     String?
  job       RedditBotJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())
}

// === Carely module ===

model CarelyParent {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdByUserId String
  createdByUser   User   @relation("CareParentsCreated", fields: [createdByUserId], references: [id])

  name        String
  dateOfBirth DateTime?
  notes       String?
  avatarUrl   String?
  // Preferred unit for temperature vitals logged for this parent.
  // Individual log entries still store their own unit.
  temperatureUnit String @default("F")

  measurements  CarelyVitalLog[]
  prescriptions CarelyPrescription[]
  collaborators CarelyCollaborator[]
}

// Co-management: other users invited to help manage a parent
model CarelyCollaborator {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  parentId  String
  parent    CarelyParent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  userId    String
  user      User   @relation("CarelyCollaborators", fields: [userId], references: [id], onDelete: Cascade)

  // Permissions
  canViewPrescription  Boolean @default(true)
  canEditPrescription  Boolean @default(false)
  canAddVitals         Boolean @default(true)
  canViewVitals        Boolean @default(true)

  @@unique([parentId, userId])
}

// Configurable vital categories (admin-managed).
// Used by the Carely UI to render chips, labels, units, and input shape.
model CarelyVitalCategory {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Stable identifier referenced by CarelyVitalLog.type (e.g. "BLOOD_PRESSURE", "WEIGHT")
  key         String   @unique
  displayName String

  // "blood_pressure" | "numeric"
  kind        String
  // For kind="numeric": unit string like "kg", "%", "bpm", "mg/dL"
  // For kind="blood_pressure": typically "mmHg" (display only; values still store unit in JSON)
  unit        String?

  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
}

// Global Carely settings (not per patient).
model CarelyAppSettings {
  id              Int     @id @default(1)
  temperatureUnit String  @default("F") // "F" | "C"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Vital measurement log entries (type is a CarelyVitalCategory.key)
model CarelyVitalLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  parentId  String
  parent    CarelyParent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  loggedByUserId String
  loggedByUser   User   @relation("CareVitalLogs", fields: [loggedByUserId], references: [id])

  // The type: references CarelyVitalCategory.key
  type      String

  // Flexible value storage per type:
  // BLOOD_PRESSURE: { systolic: 120, diastolic: 80, unit: "mmHg" }
  // GLUCOSE:        { value: 5.5, unit: "mmol/L" }
  // TEMPERATURE:    { value: 37.2, unit: "C" }
  // SPO2:           { value: 98, unit: "%" }
  // HEART_RATE:     { value: 72, unit: "bpm" }
  value     Json

  loggedAt  DateTime @default(now())
  notes     String?
}

// Prescription record for a parent
model CarelyPrescription {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parentId  String
  parent    CarelyParent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  createdByUserId String
  createdByUser   User   @relation("CarePrescriptions", fields: [createdByUserId], references: [id])

  medicineName  String
  // Standard: { type: "standard", morning: 1, afternoon: 0, evening: 0, night: 1 }
  // All four fields always stored as integers. evening=0 means not in use (renders 3-value string).
  // Custom:   { type: "custom", notes: "4 times a day, after meals" }
  doseSchedule  Json
  doseNote      String?
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean @default(true)

  intakeLogs    CarelyMedicineIntakeLog[]
}

// Daily medicine intake confirmation (check-off log)
model CarelyMedicineIntakeLog {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())

  prescriptionId String
  prescription   CarelyPrescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  loggedByUserId String
  loggedByUser   User   @relation("CareMedicineIntakeLogs", fields: [loggedByUserId], references: [id])

  // Which slot: "morning" | "afternoon" | "evening" | "night" | custom index
  slot          String
  // The date for which this intake is logged (date only, no time)
  intakeDate    DateTime
  takenAt       DateTime @default(now())

  @@unique([prescriptionId, slot, intakeDate])
}
