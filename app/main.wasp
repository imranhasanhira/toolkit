//#region Online Judge
job gradeSubmission {
  executor: PgBoss,
  perform: {
    fn: import { gradeSubmission } from "@src/server/online-judge/submissionWorker"
  },
  entities: [Submission, SubmissionTestCaseResult, Problem, TestCase]
}

route CreateProblemRoute { path: "/online-judge/create", to: CreateProblemPage }
page CreateProblemPage {
  authRequired: true,
  component: import CreateProblemPage from "@src/online-judge/CreateProblemPage"
}

route ProblemListRoute { path: "/online-judge", to: ProblemListPage }
page ProblemListPage {
  component: import ProblemListPage from "@src/online-judge/ProblemListPage"
}

route ProblemDetailRoute { path: "/online-judge/:slug", to: ProblemDetailPage }
page ProblemDetailPage {
  component: import ProblemDetailPage from "@src/online-judge/ProblemDetailPage"
}

route EditProblemRoute { path: "/online-judge/:slug/edit", to: EditProblemPage }
page EditProblemPage {
  authRequired: true,
  component: import EditProblemPage from "@src/online-judge/EditProblemPage"
}

route RuntimeListRoute { path: "/online-judge/runtimes", to: RuntimeListPage }
page RuntimeListPage {
  authRequired: true,
  component: import RuntimeListPage from "@src/online-judge/RuntimeListPage"
}

action submitCode {
  fn: import { submitCode } from "@src/online-judge/operations",
  entities: [Submission, Problem, Runtime]
}

action createProblem {
  fn: import { createProblem } from "@src/online-judge/operations",
  entities: [Problem, TestCase]
}

action runCode {
  fn: import { runCode } from "@src/online-judge/operations",
  entities: [Runtime]
}

action updateProblem {
  fn: import { updateProblem } from "@src/online-judge/operations",
  entities: [Problem, TestCase]
}

action updateRuntime {
    fn: import { updateRuntime } from "@src/online-judge/operations",
    entities: [Runtime]
}

action createRuntime {
    fn: import { createRuntime } from "@src/online-judge/operations",
    entities: [Runtime]
}

action checkRuntimeStatus {
    fn: import { checkRuntimeStatus } from "@src/online-judge/operations",
    entities: []
}

action deleteProblem {
    fn: import { deleteProblem } from "@src/online-judge/operations",
    entities: [Problem, TestCase, Submission, SubmissionTestCaseResult]
}

query getProblems {
  fn: import { getProblems } from "@src/online-judge/operations",
  entities: [Problem]
}

query getProblem {
  fn: import { getProblem } from "@src/online-judge/operations",
  entities: [Problem, TestCase]
}

query getRuntimes {
    fn: import { getRuntimes } from "@src/online-judge/operations",
    entities: [Runtime]
}

query getPublicRuntimes {
    fn: import { getPublicRuntimes } from "@src/online-judge/operations",
    entities: [Runtime]
}

query getSubmissions {
  fn: import { getSubmissions } from "@src/online-judge/operations",
  entities: [Submission, SubmissionTestCaseResult]
}


