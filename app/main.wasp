    fn: import { processRedditScheduleRunner } from "@src/server/jobs/redditScheduleRunner"
  },
  schedule: {
    cron: "0 * * * *"
  },
  entities: [User, RedditBotSchedule, RedditBotProject, RedditBotJob]
}

